# Application
SERVICE_NAME=banking-api
HTTP_ADDR=:8080
LOG_LEVEL=info
AUTO_MIGRATE=true

# Database
POSTGRES_DSN=postgres://banking:banking@localhost:5432/banking?sslmode=disable
REDIS_ADDR=localhost:6379

# CORS (Next.js frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Auth (disabled by default for local dev)
AUTH_ENABLED=false
API_KEYS=dev-banking-key-change-me

# Event bus: log | kafka
EVENT_PUBLISHER=log
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=banking.events

# Fraud limits
FRAUD_MAX_SINGLE_HALALAS=50000000
FRAUD_MAX_HOURLY_TRANSFERS=20

# Worker
WORKER_INTERVAL_SEC=3
OUTBOX_INTERVAL_SEC=2
SARIE_FAIL_RATE=0.15

# Shutdown
SHUTDOWN_TIMEOUT_SEC=10
